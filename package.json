{
  "name": "nsm-tour-hq",
  "private": true,
  "version": "1.0.0",
  "workspaces": [
    "client",
    "server",
    "remotion"
  ],
  "scripts": {
    "dev": "concurrently -n server,client -c green,cyan \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "cd server && nodemon index.js",
    "dev:client": "cd client && vite",
    "build": "cd client && vite build",
    "test": "node scripts/smoke-test.mjs",
    "start": "node server/index.js",
    "remotion:studio": "cd remotion && npx remotion studio",
    "remotion:render": "cd remotion && npx remotion render"
  },
  "devDependencies": {
    "concurrently": "^9.0.0",
    "nodemon": "^3.1.0"
  }
}
